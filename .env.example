# ─────────────────────────────────────────────────────────────
# Clínica Hispana Nueva Salud Hammerly — variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────────

# Resend (email transaccional del formulario de contacto)
RESEND_API_KEY=
# Vacío = onboarding@resend.dev. Prod (dominio verificado en Resend):
# "Clínica Hispana Nueva Salud Hammerly <noreply@clinicahispananhammerly.com>"
RESEND_FROM=

# Meta Pixel + Conversions API (tracking de leads)
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# URL pública del sitio (sin slash final, canónico con www)
NEXT_PUBLIC_SITE_URL=https://www.clinicahispananhammerly.com

# Google Analytics 4 (formato G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Ads (formato AW-XXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# CallRail — URL del swap.js de la cuenta (number swap dinámico)
# https://cdn.callrail.com/companies/<COMPANY_ID>/<HASH>/12/swap.js
NEXT_PUBLIC_CALLRAIL_SWAP_SRC=

# Google Places API (New) — server-side, alimenta rating/reseñas en vivo del JSON-LD
GOOGLE_PLACES_API_KEY=
# PENDIENTE: obtener el Place ID real (Places API o pedir al cliente)
GOOGLE_PLACE_ID=

# IndexNow (ping a buscadores; el archivo de clave se sirve desde /public/<key>.txt)
INDEXNOW_KEY=

# Verificación de Google Search Console (contenido del meta tag HTML). PENDIENTE.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
